<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!-- REFRESH TOKENS -->
    <changeSet id="003-refresh-tokens-table" author="santosh">
        <createTable tableName="refresh_tokens">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_refresh_tokens"/>
            </column>
            <column name="token_hash" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_refresh_user" references="users(id)"/>
            </column>
            <column name="expires_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="revoked" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Performance indexes -->
        <createIndex indexName="idx_refresh_token_hash" tableName="refresh_tokens">
            <column name="token_hash"/>
        </createIndex>
        <createIndex indexName="idx_refresh_user" tableName="refresh_tokens">
            <column name="user_id"/>
        </createIndex>
        <createIndex indexName="idx_refresh_expires" tableName="refresh_tokens">
            <column name="expires_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>